<Window x:Class="Clever.View.Dialogs.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Clever.View.Dialogs"
        mc:Ignorable="d"
        Title="CLEVƎR TEAM" Height="480" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="0" Background="{StaticResource about_bgd}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid Margin="20" Height="420">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>

                </Grid.RowDefinitions>
                <TextBlock Text="UI design:" Margin="5,0,0,0" Grid.Row="0" FontFamily="Calibri" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="ATOMo team." Margin="5,0,0,0" Grid.Row="1" FontFamily="Calibri" FontSize="14" VerticalAlignment="Center"/>
                <Label Grid.Row="2" Height="25">
                    <Hyperlink NavigateUri="http://atomorobotics.ru/" Click="Atom_Click">
                        <TextBlock Text="http://atomorobotics.ru/" FontFamily="Calibri" FontSize="14" VerticalAlignment="Center"/>
                    </Hyperlink>
                </Label>

                <TextBlock Text="Tests:" Margin="5,0,0,0" Grid.Row="4" FontFamily="Calibri" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="Op[ti]mum team." Margin="5,0,0,0" Grid.Row="5" FontFamily="Calibri" FontSize="14" VerticalAlignment="Center"/>
                <Label Grid.Row="6" Height="25">
                    <Hyperlink NavigateUri="https://facebook.com/optimum.robotics.team" Click="Optimum_Click">
                        <TextBlock Text="https://facebook.com/optimum.robotics.team" FontFamily="Calibri" FontSize="14" VerticalAlignment="Center"/>
                    </Hyperlink>
                </Label>

                <TextBlock Text="Development:" Margin="5,0,0,0" Grid.Row="8" FontFamily="Calibri" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="i4e][" Margin="5,0,0,0" Grid.Row="9" FontFamily="Calibri" FontSize="14" VerticalAlignment="Center"/>
                <Label Grid.Row="10" Height="25">
                    <Hyperlink NavigateUri="https://t.me/clev3r_chat" Click="Robomaks_Click">
                        <TextBlock Text="https://t.me/clev3r_chat" FontFamily="Calibri" FontSize="14" VerticalAlignment="Center"/>
                    </Hyperlink>
                </Label>
            
                <TextBlock Text="Доработка:" Margin="5,0,0,0" Grid.Row="12" FontFamily="Calibri" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="Дородицын А.В." Margin="5,0,0,0" Grid.Row="13" FontFamily="Calibri" FontSize="14" VerticalAlignment="Center" Height="26"/>
                <Label Grid.Row="14" Height="25">
                    <Hyperlink NavigateUri="https://avdor1963.ru/ob-avtore/" Click="Avdor_Click">
                        <TextBlock Text="https://t.me/clev3r_chat" FontFamily="Calibri" FontSize="14" VerticalAlignment="Top" RenderTransformOrigin="0.52,0.717"/>
                    </Hyperlink>
                </Label>
                <Label Grid.Row="15" Height="25">
                    <Hyperlink NavigateUri="https://github.com/Avdor1963?tab=repositories" Click="AvdorGit_Click">
                        <TextBlock Text="https://t.me/clev3r_chat" FontFamily="Calibri" FontSize="14" VerticalAlignment="Top" RenderTransformOrigin="0.52,0.717"/>
                    </Hyperlink>
                </Label>

            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
