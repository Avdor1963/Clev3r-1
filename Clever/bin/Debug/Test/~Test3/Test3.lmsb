}
subcall PROGRAM_MAIN
{
    IN_32 SUBPROGRAM
    DATA32 INDEX
    ARRAY8 STACKPOINTER 4
    DATAF F.0
    DATAF F.1
    DATAF F.2
    DATAF F.3
    ARRAY32 RETURNSTACK2 128
    ARRAY32 RETURNSTACK 128
    DATAS S.0 252
    DATAS S.1 252
    DATAS S.2 252
    DATAS S.3 252
    MOVE8_8 0 STACKPOINTER
    MOVEF_F 0.0 VPR_LCDRU_LAN
    MOVEF_F 0.0 VPR_LCDRU_SIZEX
    MOVEF_F 0.0 VPR_LCDRU_SIZEY
    MOVEF_F 0.0 VPR_LCDRU_SLASH
    CALL ARRAYSTORE_FLOAT 0.0 0.0 VPR_LCDRU_FONTCHARS8X8_0
    CALL ARRAYSTORE_FLOAT 0.0 0.0 VPR_LCDRU_FONTCHARS8X8_1
    CALL ARRAYSTORE_FLOAT 0.0 0.0 VPR_LCDRU_FONTCHARS16X16
    MOVEF_F 0.0 VPR_LCDRU_COUNTSTOPUPDATE
    MOVEF_F 0.0 VPR_LCDRU_ISINITFONT0
    MOVEF_F 0.0 VPR_LCDRU_ISINITFONT1
    MOVEF_F 0.0 VPR_LCDRU_ISINITFONT2
    MOVEF_F 0.0 VLV_PAR1_2
    MOVEF_F 0.0 VLV_PAR2_2
    MOVEF_F 0.0 VLV_R_MULT_2
    MOVEF_F 0.0 VLV_PAR1_1
    MOVEF_F 0.0 VLV_R_SQRT_1
    STRINGS DUPLICATE '' VLV_STRIN_11
    STRINGS DUPLICATE '' VLV_R_KLAV_11
    MOVEF_F 0.0 VLV_COLOR_4
    MOVEF_F 0.0 VLV_XST_4
    MOVEF_F 0.0 VLV_YST_4
    MOVEF_F 0.0 VLV_FONT_4
    STRINGS DUPLICATE '' VLV_TXT_4
    MOVEF_F 0.0 VLV_PORT_15
    MOVEF_F 0.0 VLV_VALUE_15
    MOVEF_F 0.0 VLV_COLOR_5
    MOVEF_F 0.0 VLV_X_5
    MOVEF_F 0.0 VLV_Y_5
    MOVEF_F 0.0 VLV_FONT_5
    STRINGS DUPLICATE '' VLV_CHR_5
    MOVEF_F 0.0 VLV_RES_5
    STRINGS DUPLICATE '' VLV_CHR_6
    MOVEF_F 0.0 VLV_COD_6
    MOVEF_F 0.0 VLV_RES_6
    MOVEF_F 0.0 VLV_FNT_8
    MOVEF_F 0.0 VLV_COLOR_9
    MOVEF_F 0.0 VLV_X_9
    MOVEF_F 0.0 VLV_Y_9
    MOVEF_F 0.0 VLV_LAN_12
    MOVEF_F 0.0 VLV_CAPS_12
    MOVEF_F 0.0 VLV_FONT_12
    CALL ARRAYSTORE_STRING 0.0 '' VLV_CHAR_12
    MOVEF_F 0.0 VLV_COL_13
    MOVEF_F 0.0 VLV_XS_13
    MOVEF_F 0.0 VLV_FONT_13
    STRINGS DUPLICATE '' VLV_CHR_13
    MOVEF_F 0.0 VLV_COL_14
    MOVEF_F 0.0 VLV_X_14
    MOVEF_F 0.0 VLV_Y_14
    MOVEF_F 0.0 VLV_FONT_14
    STRINGS DUPLICATE '' VLV_CHR_14
    MOVEF_F 0.0 VGV_F_MULT
    MOVEF_F 0.0 VGV_F_SQRT
    MOVEF_F 0.0 VGV_F_MULT_1
    MOVEF_F 0.0 VGV_F_SQRT_1
    STRINGS DUPLICATE '' VGV_F_KLAV_KLAV
    MOVEF_F 0.0 VGV_S
    MOVEF_F 0.0 VLV_RES_4
    MOVEF_F 0.0 VLV_COD_5
    MOVEF_F 0.0 VLV_RES_5
    CALL ARRAYSTORE_STRING 0.0 '' VLV_CHR_11
    MOVEF_F 0.0 VLV_RES_14
    MOVEF_F 0.0 VGV_A1
    MOVEF_F 0.0 VGV_A2
    STRINGS DUPLICATE '' VGV_SS
    WRITE32 ENDSUB_M_LCDRU_CLEAR_0:CALLSUB5 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_M_LCDRU_CLEAR_0
CALLSUB5:
    MOVEF_F 15.0 VLV_PAR1_2
    MOVEF_F 10.0 VLV_PAR2_2
    WRITE32 ENDSUB_F_MULT_3:CALLSUB6 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_F_MULT_3
CALLSUB6:
    MOVEF_F VLV_R_MULT_2 VGV_F_MULT
    MOVEF_F 10.0 VLV_PAR1_1
    WRITE32 ENDSUB_F_SQRT_2:CALLSUB7 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_F_SQRT_2
CALLSUB7:
    MOVEF_F VLV_R_SQRT_1 VGV_F_SQRT
    MOVEF_F 0.0 VLV_PAR1_2
    MOVEF_F 0.0 VLV_PAR2_2
    WRITE32 ENDSUB_F_MULT_3:CALLSUB8 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_F_MULT_3
CALLSUB8:
    MOVEF_F VLV_R_MULT_2 VGV_F_MULT_1
    MOVEF_F 11.0 VLV_PAR1_1
    WRITE32 ENDSUB_F_SQRT_2:CALLSUB9 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_F_SQRT_2
CALLSUB9:
    MOVEF_F VLV_R_SQRT_1 VGV_F_SQRT_1
    SUBF 155.0 VGV_F_MULT F.3
    ADDF F.3 VGV_F_SQRT F.2
    ADDF F.2 VGV_F_MULT_1 F.1
    ADDF F.1 VGV_F_SQRT_1 F.0
    ADDF F.0 10.0 VGV_A1
    MOVEF_F 5.0 VLV_PAR1_1
    WRITE32 ENDSUB_F_SQRT_2:CALLSUB15 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_F_SQRT_2
CALLSUB15:
    MOVEF_F VLV_R_SQRT_1 VGV_F_SQRT
    JR_LTEQF VGV_F_SQRT 0.0 else16_1
    MOVEF_F 6.0 VLV_PAR1_1
    WRITE32 ENDSUB_F_SQRT_2:CALLSUB17 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_F_SQRT_2
CALLSUB17:
    MOVEF_F VLV_R_SQRT_1 VGV_F_SQRT
    MOVEF_F 7.0 VLV_PAR1_2
    MOVEF_F 5.0 VLV_PAR2_2
    WRITE32 ENDSUB_F_MULT_3:CALLSUB18 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_F_MULT_3
CALLSUB18:
    MOVEF_F VLV_R_MULT_2 VGV_F_MULT
    ADDF VGV_F_SQRT VGV_F_MULT VGV_A2
    MOVEF_F 2.0 VLV_PAR1_1
    WRITE32 ENDSUB_F_SQRT_2:CALLSUB20 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_F_SQRT_2
CALLSUB20:
    MOVEF_F VLV_R_SQRT_1 VGV_F_SQRT
    MOVEF_F 3.0 VLV_PAR1_2
    MOVEF_F 2.0 VLV_PAR2_2
    WRITE32 ENDSUB_F_MULT_3:CALLSUB21 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_F_MULT_3
CALLSUB21:
    MOVEF_F VLV_R_MULT_2 VGV_F_MULT
    STRINGS VALUE_FORMATTED VGV_F_SQRT '%g' 99 S.3
    CALL TEXT.APPEND ' ' S.3 S.2
    CALL TEXT.APPEND S.2 ' ' S.1
    STRINGS VALUE_FORMATTED VGV_F_MULT '%g' 99 S.2
    CALL TEXT.APPEND S.1 S.2 S.0
    CALL LCD.TEXT 1.0 10.0 20.0 2.0 S.0
  else16_1:
  endif16:
    UI_BUTTON WAIT_FOR_PRESS
    CALL BUTTONS.GETCLICKS S.0
    STRINGS DUPLICATE ' /0GHBDTN' VLV_STRIN_11
    WRITE32 ENDSUB_M_KLAV_KLAV_2:CALLSUB30 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_M_KLAV_KLAV_2
CALLSUB30:
    STRINGS DUPLICATE VLV_R_KLAV_11 VGV_F_KLAV_KLAV
    STRINGS DUPLICATE VGV_F_KLAV_KLAV VGV_SS
    MOVEF_F 1.0 VLV_COLOR_4
    MOVEF_F 0.0 VLV_XST_4
    MOVEF_F 50.0 VLV_YST_4
    MOVEF_F 2.0 VLV_FONT_4
    STRINGS DUPLICATE VGV_SS VLV_TXT_4
    WRITE32 ENDSUB_M_LCDRU_TEXTRU_5:CALLSUB31 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_M_LCDRU_TEXTRU_5
CALLSUB31:
    CALL LCD.BMPFILE 1.0 40.0 80.0 'BrkProg_SAVE/Media/EV3'
    UI_BUTTON WAIT_FOR_PRESS
    MOVEF_F 1.0 VLV_PORT_15
    WRITE32 ENDSUB_M_LIGHT_GETRAW_2:CALLSUB34 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_M_LIGHT_GETRAW_2
CALLSUB34:
    MOVEF_F VLV_VALUE_15 VGV_S
    UI_BUTTON WAIT_FOR_PRESS
ENDTHREAD:
    RETURN
SUB_F_SQRT_2:
    MULF VLV_PAR1_1 VLV_PAR1_1 VLV_R_SQRT_1
    JR LRETURN_1
  LRETURN_1:
RETSUB_F_SQRT_2:
    SUB8 STACKPOINTER 1 STACKPOINTER
    READ32 RETURNSTACK STACKPOINTER INDEX
    JR_DYNAMIC INDEX
ENDSUB_F_SQRT_2:
SUB_F_MULT_3:
    MULF VLV_PAR1_2 VLV_PAR2_2 VLV_R_MULT_2
    JR LRETURN_2
  LRETURN_2:
RETSUB_F_MULT_3:
    SUB8 STACKPOINTER 1 STACKPOINTER
    READ32 RETURNSTACK STACKPOINTER INDEX
    JR_DYNAMIC INDEX
ENDSUB_F_MULT_3:
SUB_M_LCDRU_CLEAR_0:
    CALL LCD.CLEAR
RETSUB_M_LCDRU_CLEAR_0:
    SUB8 STACKPOINTER 1 STACKPOINTER
    READ32 RETURNSTACK STACKPOINTER INDEX
    JR_DYNAMIC INDEX
ENDSUB_M_LCDRU_CLEAR_0:
SUB_M_LCDRU_TEXTRU_5:
    MOVEF_F VPR_LCDRU_LAN VLV_LANST_4
    MOVEF_F VPR_LCDRU_SIZEX VLV_SIZEXST_4
    MOVEF_F VPR_LCDRU_SIZEY VLV_SIZEYST_4
    JR_NEQF VLV_FONT_4 2.0 else39_1
    MOVEF_F 16.0 VPR_LCDRU_SIZEX
    MOVEF_F 16.0 VPR_LCDRU_SIZEY
    JR endif39
  else39_1:
    MOVEF_F 8.0 VPR_LCDRU_SIZEX
    MOVEF_F 8.0 VPR_LCDRU_SIZEY
  else39_2:
  endif39:
    MOVEF_F 1.0 VPR_LCDRU_LAN
    MOVEF_F 0.0 VPR_LCDRU_SLASH
    MOVEF_F VLV_XST_4 VLV_XC_4
    MOVEF_F VLV_YST_4 VLV_YC_4
    MOVEF_F 1.0 VLV_I_4
  for40:
    CALL TEXT.GETLENGTH VLV_TXT_4 F.0
    JR_GTF VLV_I_4 F.0 endfor40
  forbody40:
    CALL TEXT.GETSUBTEXT VLV_TXT_4 VLV_I_4 1.0 VLV_TEKCHAR_4
    MOVEF_F VLV_COLOR_4 VLV_COLOR_5
    MOVEF_F VLV_XC_4 VLV_X_5
    MOVEF_F VLV_YC_4 VLV_Y_5
    MOVEF_F VLV_FONT_4 VLV_FONT_5
    STRINGS DUPLICATE VLV_TEKCHAR_4 VLV_CHR_5
    WRITE32 ENDSUB_M_LCDRU_PRINTCHAR_6:CALLSUB43 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
    JR SUB_M_LCDRU_PRINTCHAR_6
CALLSUB43:
    MOVEF_F VLV_RES_5 VLV_RES_4
    JR_EQF VLV_RES_4 2.0 else44_1
    ADDF VLV_XC_4 VPR_LCDRU_SIZEX VLV_XC_4
  else44_1:
  endif44:
    ADDF VLV_I_4 1.0 VLV_I_4
    CALL TEXT.GETLENGTH VLV_TXT_4 F.0
    JR_LTEQF VLV_I_4 F.0 forbody40
  endfor40:
    MOVEF_F VLV_LANST_4 VPR_LCDRU_LAN
    MOVEF_F VLV_SIZEXST_4 VPR_LCDRU_SIZEX
    MOVEF_F VLV_SIZEYST_4 VPR_LCDRU_SIZEY
RETSUB_M_LCDRU_TEXTRU_5:
    SUB8 STACKPOINTER 1 STACKPOINTER
    READ32 RETURNSTACK STACKPOINTER INDEX
    JR_DYNAMIC INDEX
