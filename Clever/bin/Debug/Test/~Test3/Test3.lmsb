    SUBF 1.0 VLV_COL_14 F.0
    MULF VLV_X_14 16.0 F.2
    ADDF 2.0 F.2 F.1
    MULF VLV_Y_14 20.0 F.3
    ADDF 26.0 F.3 F.2
    CALL LCD.FILLRECT F.0 F.1 F.2 13.0 17.0
    MOVEF_F VLV_COL_14 VLV_COLOR_5
    MULF VLV_X_14 16.0 F.0
    ADDF 4.0 F.0 VLV_X_5
    MULF VLV_Y_14 20.0 F.0
    ADDF 30.0 F.0 VLV_Y_5
    MOVEF_F VLV_FONT_14 VLV_FONT_5
    STRINGS DUPLICATE VLV_CHR_14 VLV_CHR_5
    WRITE32 ENDSUB_M_LCDRU_PRINTCHAR_6:CALLSUB373 STACKPOINTER RETURNSTACK
    ADD8 STACKPOINTER 1 STACKPOINTER
