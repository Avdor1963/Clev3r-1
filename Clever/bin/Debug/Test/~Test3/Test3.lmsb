    DATA8 layer374
	DATA8 no374
	DATA8 mode8374
	
	MOVEF_8 VLV_PORT_15 no374
	SUB8 no374 1 no374
	DIV8 no374 4 layer374
	MATH MOD8 no374 4 no374

	MOVEF_8 3.0 mode8374
	
	INPUT_DEVICE READY_RAW layer374 no374 0 mode8374 0
    CALL SENSOR.READRAWVALUE VLV_PORT_15 0.0 VLV_VALUE_15
