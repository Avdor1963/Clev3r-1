subcall TEXT.STARTSWITH    // SSS
{
	IN_S a 252
	IN_S b 252
	OUT_S result 8
	DATAS MEMORY 252  // starts at 512

	DATA16 len0
	DATA16 len1
	DATA8 flag
	
	STRINGS GET_SIZE a len0
	STRINGS GET_SIZE b len1
	JR_LT16 len0 len1 deliverfalse     // second string is longer
	JR_EQ16 len1 0 deliverfalse        // second string is empty
	JR_GT16 len0 len1 hasoversize	   

	STRINGS COMPARE a b flag           // have same size	
	JR_EQ8 0 flag deliverfalse
	STRINGS DUPLICATE 'True' result
	RETURN
	
hasoversize:
    DATA32 size
	MOVE16_32 len1 size
	MEMORY_WRITE 1 TEXT.STARTSWITH 512 size a
	DATA32 offset
	ADD32 512 size offset
	MEMORY_WRITE 1 TEXT.STARTSWITH offset 1 ''
	STRINGS COMPARE MEMORY b flag
	JR_EQ8 0 flag deliverfalse
	STRINGS DUPLICATE 'True' result
    RETURN
	
deliverfalse:
	STRINGS DUPLICATE 'False' result
}
subcall ARRAYGET_STRING   // FFS
{
	IN_F index
	OUT_S value 252	
	IN_16 handle

	DATA32 index32
	MOVEF_32 index index32
	
	MUL32 252 index32 index32 // every string has 252 bytes
	MOVE8_8 0 value		  // set to empty string in case that nothing can be read
	
	ARRAY READ_CONTENT 1 handle index32 252 value   // transfer memory from program slot 1
}
subcall TEXT.ENDSWITH    // SSS
{
	IN_S a 252
	IN_S b 252
	OUT_S result 8
	DATAS MEMORY 252  // starts at 512
	
	DATA16 len0
	DATA16 len1
	DATA8 flag
	
	STRINGS GET_SIZE a len0
	STRINGS GET_SIZE b len1
	JR_LT16 len0 len1 deliverfalse     // second string is longer
	JR_EQ16 len1 0 deliverfalse        // second string is empty
	JR_GT16 len0 len1 hasoversize	

	STRINGS COMPARE a b flag           // have same size	
	JR_EQ8 0 flag deliverfalse
	STRINGS DUPLICATE 'True' result
	RETURN
	
hasoversize:	
	DATA16 oversize
	SUB16 len0 len1 oversize
	DATA32 offset
	MOVE16_32 oversize offset
	DATA32 size
	MOVE16_32 len1 size
	ADD32 size 1 size
	STRINGS DUPLICATE a MEMORY
	// THIS IS THE ONLY METHOD AVAILABLE FOR INDIRECT ADDRESSING	
	// (assumes that the current program runs in slot 1)	
	ADD32 offset 512 offset
	MEMORY_READ 1 TEXT.ENDSWITH offset size MEMORY
	
	STRINGS COMPARE MEMORY b flag
	JR_EQ8 0 flag deliverfalse
	STRINGS DUPLICATE 'True' result
	RETURN
	
deliverfalse:
	STRINGS DUPLICATE 'False' result
}
subcall TEXT.GETSUBTEXTTOEND     // SFS
{
	IN_S a 252
	IN_F start_f 
	OUT_S result 252
	DATAS MEMORY 252  // starts at 508

	DATA16 start
	MOVEF_16 start_f start	
	SUB16 start 1 start   // use index 0 for start instead of index 1
	DATA16 len
	STRINGS GET_SIZE a len
	
	JR_LT16 start 0 nothingremains
	JR_GTEQ16 start len nothingremains
	
	STRINGS DUPLICATE a MEMORY
	DATA32 offset	
	MOVE16_32 start offset
	DATA32 size
	MOVE16_32 len size
	SUB32 size offset size
	ADD32 size 1 size
	ADD32 offset 508 offset 
	MEMORY_READ 1 TEXT.GETSUBTEXTTOEND offset size result
	RETURN
	
nothingremains:
	STRINGS DUPLICATE '', result
}
subcall TEXT.GETCHARACTER   // FS
{
	IN_F c_f
	OUT_S result 2
	
	DATA32 c	
	MOVEF_32 c_f c
		
   	STRINGS DUPLICATE ' ' result

	JR_LT32 c,1,unsupported
	JR_GT32 c,255,unsupported	
	
	MOVE32_8 c result
	RETURN
  unsupported:
	MOVE8_8 1 result
}
subcall SENSOR.READRAWVALUE            // FFF
{
	IN_F port
	IN_F index
	OUT_F result

	DATA8 layer
	DATA8 no
	DATA8 index8
		
	MOVEF_8 port no
	SUB8 no 1 no
	DIV8 no 4 layer
	MATH MOD8 no 4 no

	MOVEF_8 index index8
	JR_LT8 index8 0 outofbounds
	JR_GT8 index8 7 outofbounds

	DATA32 rawvalue0
	DATA32 rawvalue1
	DATA32 rawvalue2
	DATA32 rawvalue3
	DATA32 rawvalue4
	DATA32 rawvalue5
	DATA32 rawvalue6
	DATA32 rawvalue7
	INPUT_READEXT layer no 0 -1 18 8 rawvalue0 rawvalue1 rawvalue2 rawvalue3 rawvalue4 rawvalue5 rawvalue6 rawvalue7
	
	DATA32 rawtmp
	READ32 rawvalue0 index8 rawtmp

	JR_LT32 rawtmp -1000000000 nomoredata
	MOVE32_F rawtmp result
	RETURN

nomoredata:
outofbounds:
	MOVEF_F 0.0 result
}
subcall ARRAYCREATE_FLOAT   // F
{
	OUT_16 handle
	
	ARRAY CREATEF 8 handle			// create with 8 elements
	ARRAY FILL handle 0.0
}
subcall ARRAYCREATE_STRING   // F
{
	OUT_16 handle

	DATA8 z
	
	ARRAY CREATE8 504  handle     // 504 bytes are enough to store 2 strings
	MOVE8_8 0 z
	ARRAY FILL handle z
}
