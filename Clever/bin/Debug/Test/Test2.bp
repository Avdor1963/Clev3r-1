import "primer"                     ' загружаем модуль примера
primer.SetPP(primer.GetLL())     ' работает, но, так как задаем -200, то в свойство PP будет записан 0
N = primer.GetLL()                  ' работает - хотя глобальная переменная primer.LL не задана, по умолчанию она равна 00
primer.SetLL(10)                    ' работает LL = 10
N = primer.LL                       ' работает N = 10
primer.LL = 20                      ' работает LL = 20
primer.SetLL(-10)                   ' работает, но записывается в LL = 0 
N = primer.LL                       ' работает N = 0
primer.LL = -20                     ' работает и записывается в LL = -20
N = primer.GetPP()                  ' работает N = 0
primer.SetAbsPP(-9)                 ' работает в приватное свойство primer.PP запишется 9
N = primer.GetPP() * 10             ' работает N = 90
primer.SetPP(15)                    ' работает, но запишется в primer.PP = 10, так как PP должно быть в диапазоне от 0 до 10.
primer.SetAbsPP(primer.LL-10)       ' работает, но, так как задаем -30 и |-30| = 30, то в свойство PP будет записана 10
primer.SetPP(primer.GetLL())     ' работает, но, так как задаем -200, то в свойство PP будет записан 0
