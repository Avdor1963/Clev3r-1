    MOVEF_F 0.0 VLV_CAPS_12
    MOVEF_F 0.0 VLV_FONT_12
    CALL ARRAYCREATE_STRING VLV_CHAR_12
    MOVEF_F 0.0 VLV_COL_13
    MOVEF_F 0.0 VLV_XS_13
    MOVEF_F 0.0 VLV_FONT_13
